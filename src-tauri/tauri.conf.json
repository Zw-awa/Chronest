{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chronest",
  "version": "0.1.0",
  "identifier": "com.chronest.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Chronest",
        "width": 411,
        "height": 536,
        "minWidth": 390,
        "minHeight": 528,
        "resizable": true,
        "center": true,
        "transparent": false,
        "backgroundColor": "#F4F6F8",
        "decorations": true,
        "shadow": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
